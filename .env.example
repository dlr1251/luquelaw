# Site URL (production canonical domain)
NEXT_PUBLIC_SITE_URL=https://luquelaw.co

# Analytics & Search Console (optional — set in Vercel Production)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GOOGLE_SITE_VERIFICATION=your_verification_token

# Supabase (required for login, client portal, and CLKR admin)
# Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Optional alias (newer Supabase dashboards):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Admin access (comma-separated emails allowed to use /admin)
ADMIN_EMAILS=daniel@luquelaw.co,asistente@luquelaw.co,mateo.abogado1@gmail.com,camiloauribeg@gmail.com

# Booking embed — Google Calendar Appointment Scheduling (SINGLE page only)
# Must include `/schedules/` or the iframe lists every consultation type.
# Calendar → Booking pages → hover “45-minute…” → Options → Sharing options →
# Website embed → “A single booking page” → Inline booking page → copy iframe src.
# Docs: https://support.google.com/calendar/answer/10733297
NEXT_PUBLIC_BOOKING_URL=https://calendar.google.com/calendar/appointments/schedules/YOUR_SCHEDULE_ID?gv=true

# Contact form — Resend (recommended: attachments + team + user confirmation)
RESEND_API_KEY=re_xxxxxxxx
# Must be a verified sender in Resend (e.g. contacto@luquelaw.co)
CONTACT_FROM_EMAIL="Luque Law <contacto@luquelaw.co>"
NEXT_PUBLIC_CONTACT_FORM_USE_API=true
# Optional overrides:
# CONTACT_TEAM_EMAILS=daniel@luquelaw.co,asistente@luquelaw.co
# When using onboarding@resend.dev for local testing, only this address can receive mail:
# CONTACT_FROM_EMAIL="Luque Law <onboarding@resend.dev>"
# CONTACT_SANDBOX_TO=daniel@luquelaw.co

# Stripe (subscriptions — optional until Phase C goes live)
# Use sk_test_* / pk_test_* in local/preview; switch to sk_live_* / pk_live_* in Vercel Production.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Price IDs (Dashboard → Products). Used when plans.stripe_price_id is null in DB.
# STRIPE_PRICE_PROFESSIONAL=price_xxx
# STRIPE_PRICE_CLIENT=price_xxx
# Production checklist: live keys + webhook endpoint → /api/stripe/webhook + SUPABASE_SERVICE_ROLE_KEY

# Lucy (AI consultations — AI Gateway + wallet)
# On Vercel, AI Gateway uses OIDC; locally set AI_GATEWAY_API_KEY from Vercel dashboard
# AI_GATEWAY_API_KEY=
# Torny (eve) requires Node 24.x — see package.json engines
LUCY_MODEL=anthropic/claude-sonnet-4.5
LUCY_EMBEDDING_MODEL=openai/text-embedding-3-small
LUCY_MIN_BALANCE_CENTS=5
LUCY_INPUT_CENTS_PER_1K=30
LUCY_OUTPUT_CENTS_PER_1K=150
LUCY_REVIEW_FEE_CENTS=15000

# Supabase service role (webhooks, seed/index scripts — never expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# After applying lucy_knowledge_rag migration: npm run index:lucy-rag

# CLKR article generation pipeline (scripts/clkr-gen)
# NOTION_TOKEN=secret_xxx
# CLKR_GEN_MODEL=anthropic/claude-sonnet-4.5
# Optional RAG guide slug allowlist (comma-separated). Empty = all published guides.
# LUCY_GUIDE_SLUGS=
