# Supabase (required for login, client portal, and CLKR admin)
# Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Optional alias (newer Supabase dashboards):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Admin access (comma-separated emails allowed to use /admin)
ADMIN_EMAILS=daniel@luquelaw.co

# Booking modal (Google Calendar appointment schedule)
NEXT_PUBLIC_BOOKING_URL=https://calendar.app.google/your-link

# Contact form — Formspree (simplest)
# NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Contact form — via API route + Resend/Formspree server-side
# CONTACT_FORM_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
# NEXT_PUBLIC_CONTACT_FORM_USE_API=true
